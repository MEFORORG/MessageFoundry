{
  "name": "messagefoundry",
  "displayName": "MessageFoundry",
  "description": "Author, test, and monitor MessageFoundry HL7 v2 interfaces in VS Code.",
  "version": "0.0.24",
  "publisher": "messagefoundry",
  "icon": "media/icon.png",
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "https://github.com/MEFORORG/MessageFoundry"
  },
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Programming Languages",
    "Testing",
    "Other"
  ],
  "activationEvents": [
    "onLanguage:python",
    "workspaceContains:**/*.py"
  ],
  "main": "./dist/extension.js",
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": "limited",
      "description": "In an untrusted workspace, MessageFoundry will not auto-run the workspace Python CLI (validate/graph/codeset/promote are disabled) until you trust the workspace."
    }
  },
  "contributes": {
    "commands": [
      {
        "command": "messagefoundry.validate",
        "title": "MessageFoundry: Validate Config",
        "icon": "media/check-amber.svg"
      },
      {
        "command": "messagefoundry.openTestBench",
        "title": "MessageFoundry: Open Test Bench",
        "icon": "media/beaker-amber.svg"
      },
      {
        "command": "messagefoundry.refreshGraph",
        "title": "MessageFoundry: Refresh Connections",
        "icon": "media/refresh-amber.svg"
      },
      {
        "command": "messagefoundry.filterConnections",
        "title": "MessageFoundry: Filter Connections",
        "icon": "media/filter-amber.svg"
      },
      {
        "command": "messagefoundry.groupConnections",
        "title": "MessageFoundry: Group Connections",
        "icon": "media/list-tree-amber.svg"
      },
      {
        "command": "messagefoundry.toggleGraphPerspective",
        "title": "MessageFoundry: Toggle Element / Flow View",
        "icon": "media/arrow-swap-amber.svg"
      },
      {
        "command": "messagefoundry.openConnectionSettings",
        "title": "MessageFoundry: Open Connection Settings",
        "icon": "media/gear-amber.svg"
      },
      {
        "command": "messagefoundry.newConnection",
        "title": "MessageFoundry: Connection Wizard"
      },
      {
        "command": "messagefoundry.editConnection",
        "title": "MessageFoundry: Edit Connection"
      },
      {
        "command": "messagefoundry.cloneConnection",
        "title": "MessageFoundry: Clone Connection"
      },
      {
        "command": "messagefoundry.newCodeSet",
        "title": "MessageFoundry: New Translation Table",
        "icon": "media/add-amber.svg"
      },
      {
        "command": "messagefoundry.editCodeSet",
        "title": "MessageFoundry: Edit Translation Table"
      },
      {
        "command": "messagefoundry.renameCodeSet",
        "title": "MessageFoundry: Rename Translation Table"
      },
      {
        "command": "messagefoundry.deleteCodeSet",
        "title": "MessageFoundry: Delete Translation Table"
      },
      {
        "command": "messagefoundry.refreshCodeSets",
        "title": "MessageFoundry: Refresh Translation Tables",
        "icon": "media/refresh-amber.svg"
      },
      {
        "command": "messagefoundry.newRoute",
        "title": "MessageFoundry: Route Wizard"
      },
      {
        "command": "messagefoundry.newRouter",
        "title": "MessageFoundry: Router Wizard"
      },
      {
        "command": "messagefoundry.newHandler",
        "title": "MessageFoundry: Handler Wizard"
      },
      {
        "command": "messagefoundry.newAlert",
        "title": "MessageFoundry: Alert Wizard"
      },
      {
        "command": "messagefoundry.generateSamples",
        "title": "MessageFoundry: Generate Samples"
      },
      {
        "command": "messagefoundry.setupSourceControl",
        "title": "MessageFoundry: Set Up Version Control & Checks"
      },
      {
        "command": "messagefoundry.setRepoStorage",
        "title": "MessageFoundry: Config Repo Storage Location"
      },
      {
        "command": "messagefoundry.promote",
        "title": "MessageFoundry: Stage → Promote",
        "icon": "media/rocket-amber.svg"
      },
      {
        "command": "messagefoundry.insertElement",
        "title": "MessageFoundry: Insert Element",
        "icon": "media/symbol-snippet-amber.svg"
      },
      {
        "command": "messagefoundry.openCookbook",
        "title": "MessageFoundry: Open Cookbook",
        "icon": "media/book-amber.svg"
      },
      {
        "command": "messagefoundry.showAiPolicy",
        "title": "MessageFoundry: Show AI Policy"
      },
      {
        "command": "messagefoundry.showVersion",
        "title": "MessageFoundry: About / Version",
        "icon": "$(info)"
      },
      {
        "command": "messagefoundry.toggleLiveDebug",
        "title": "MessageFoundry: Toggle Live Debug",
        "icon": "$(pulse)"
      },
      {
        "command": "messagefoundry.toggleRevealValues",
        "title": "MessageFoundry: Reveal Values (Live Debug)",
        "icon": "$(eye)"
      },
      {
        "command": "messagefoundry.newConnectionQuickInput",
        "title": "MessageFoundry: New Connection (Keyboard Wizard)"
      },
      {
        "command": "messagefoundry.openEngineSettings",
        "title": "MessageFoundry: Configure Engine Target"
      },
      {
        "command": "messagefoundry.openSettings",
        "title": "MessageFoundry: Settings",
        "icon": "media/gear-amber.svg"
      },
      {
        "command": "messagefoundry.openConfigDir",
        "title": "MessageFoundry: Open Config Folder"
      },
      {
        "command": "messagefoundry.openSteps",
        "title": "MessageFoundry: View as Steps",
        "icon": "media/list-tree-amber.svg"
      },
      {
        "command": "messagefoundry.engineStatusClicked",
        "title": "MessageFoundry: Engine Status Actions"
      },
      {
        "command": "messagefoundry.openWiringMap",
        "title": "MessageFoundry: Open Wiring Map",
        "icon": "media/type-hierarchy-amber.svg"
      },
      {
        "command": "messagefoundry.showInWiringMap",
        "title": "Show in Wiring Map",
        "icon": "media/type-hierarchy-amber.svg"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "messagefoundry",
          "title": "MessageFoundry",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "messagefoundry": [
        {
          "id": "messagefoundry.home",
          "name": "Home",
          "type": "webview"
        },
        {
          "id": "messagefoundry.graph",
          "name": "Connections"
        },
        {
          "id": "messagefoundry.codesets",
          "name": "Translation Tables"
        }
      ]
    },
    "submenus": [
      {
        "id": "messagefoundry.editorMenu",
        "label": "MessageFoundry",
        "icon": "media/icon-amber.svg"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "messagefoundry.openSteps",
          "when": "messagefoundry.isConfigFile && activeCustomEditorId != messagefoundry.stepsEditor",
          "group": "navigation@1"
        },
        {
          "command": "messagefoundry.openTestBench",
          "when": "messagefoundry.isConfigFile && activeCustomEditorId != messagefoundry.stepsEditor",
          "group": "navigation@2"
        },
        {
          "command": "messagefoundry.validate",
          "when": "messagefoundry.isConfigFile && activeCustomEditorId != messagefoundry.stepsEditor",
          "group": "navigation@3"
        },
        {
          "submenu": "messagefoundry.editorMenu",
          "when": "messagefoundry.isConfigFile",
          "group": "navigation@4"
        }
      ],
      "messagefoundry.editorMenu": [
        {
          "command": "messagefoundry.validate",
          "group": "1_build@1"
        },
        {
          "command": "messagefoundry.openTestBench",
          "group": "1_build@2"
        },
        {
          "command": "messagefoundry.promote",
          "group": "1_build@3"
        },
        {
          "command": "messagefoundry.newRouter",
          "group": "2_scaffold@1"
        },
        {
          "command": "messagefoundry.newHandler",
          "group": "2_scaffold@2"
        },
        {
          "command": "messagefoundry.insertElement",
          "group": "2_scaffold@3"
        },
        {
          "command": "messagefoundry.openCookbook",
          "group": "2_scaffold@4"
        },
        {
          "command": "messagefoundry.openSteps",
          "group": "3_view@1"
        }
      ],
      "view/title": [
        {
          "command": "messagefoundry.filterConnections",
          "when": "view == messagefoundry.graph",
          "group": "navigation@1"
        },
        {
          "command": "messagefoundry.groupConnections",
          "when": "view == messagefoundry.graph",
          "group": "navigation@2"
        },
        {
          "command": "messagefoundry.toggleGraphPerspective",
          "when": "view == messagefoundry.graph",
          "group": "navigation@3"
        },
        {
          "command": "messagefoundry.openTestBench",
          "when": "view == messagefoundry.graph",
          "group": "navigation@4"
        },
        {
          "command": "messagefoundry.refreshGraph",
          "when": "view == messagefoundry.graph",
          "group": "navigation@5"
        },
        {
          "command": "messagefoundry.openWiringMap",
          "when": "view == messagefoundry.graph",
          "group": "navigation@6"
        },
        {
          "command": "messagefoundry.newCodeSet",
          "when": "view == messagefoundry.codesets",
          "group": "navigation@1"
        },
        {
          "command": "messagefoundry.refreshCodeSets",
          "when": "view == messagefoundry.codesets",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "messagefoundry.openConnectionSettings",
          "when": "view == messagefoundry.graph && viewItem == meforConnection",
          "group": "inline@1"
        },
        {
          "command": "messagefoundry.showInWiringMap",
          "when": "view == messagefoundry.graph && viewItem == meforConnection",
          "group": "inline@2"
        },
        {
          "command": "messagefoundry.editConnection",
          "when": "view == messagefoundry.graph && viewItem == meforConnection",
          "group": "1_edit"
        },
        {
          "command": "messagefoundry.cloneConnection",
          "when": "view == messagefoundry.graph && viewItem == meforConnection",
          "group": "1_edit"
        },
        {
          "command": "messagefoundry.showInWiringMap",
          "when": "view == messagefoundry.graph && viewItem == meforConnection",
          "group": "2_view"
        },
        {
          "command": "messagefoundry.showInWiringMap",
          "when": "view == messagefoundry.graph && viewItem == meforElement",
          "group": "inline"
        },
        {
          "command": "messagefoundry.showInWiringMap",
          "when": "view == messagefoundry.graph && viewItem == meforElement",
          "group": "2_view"
        },
        {
          "command": "messagefoundry.editCodeSet",
          "when": "view == messagefoundry.codesets && viewItem == meforCodeSetCsv",
          "group": "1_edit"
        },
        {
          "command": "messagefoundry.editCodeSet",
          "when": "view == messagefoundry.codesets && viewItem == meforCodeSetToml",
          "group": "1_edit"
        },
        {
          "command": "messagefoundry.renameCodeSet",
          "when": "view == messagefoundry.codesets && viewItem == meforCodeSetCsv",
          "group": "1_edit"
        },
        {
          "command": "messagefoundry.deleteCodeSet",
          "when": "view == messagefoundry.codesets && (viewItem == meforCodeSetCsv || viewItem == meforCodeSetToml)",
          "group": "9_danger"
        }
      ],
      "commandPalette": [
        {
          "command": "messagefoundry.engineStatusClicked",
          "when": "false"
        },
        {
          "command": "messagefoundry.showInWiringMap",
          "when": "false"
        },
        {
          "command": "messagefoundry.editConnection",
          "when": "false"
        },
        {
          "command": "messagefoundry.cloneConnection",
          "when": "false"
        },
        {
          "command": "messagefoundry.editCodeSet",
          "when": "false"
        },
        {
          "command": "messagefoundry.renameCodeSet",
          "when": "false"
        },
        {
          "command": "messagefoundry.deleteCodeSet",
          "when": "false"
        }
      ]
    },
    "keybindings": [
      {
        "command": "messagefoundry.insertElement",
        "key": "ctrl+alt+i",
        "mac": "cmd+alt+i",
        "when": "editorTextFocus && messagefoundry.isConfigFile"
      }
    ],
    "snippets": [
      {
        "language": "python",
        "path": "./snippets/messagefoundry.code-snippets"
      }
    ],
    "languages": [
      {
        "id": "toml",
        "aliases": [
          "TOML"
        ],
        "extensions": [
          ".toml"
        ],
        "filenames": [
          "connections.toml",
          "messagefoundry.toml"
        ],
        "configuration": "./language-configuration.toml.json"
      }
    ],
    "customEditors": [
      {
        "viewType": "messagefoundry.connectionsEditor",
        "displayName": "MessageFoundry Connections",
        "selector": [
          {
            "filenamePattern": "**/connections.toml"
          }
        ],
        "priority": "default"
      },
      {
        "viewType": "messagefoundry.codeSetEditor",
        "displayName": "MessageFoundry Translation Table",
        "selector": [
          {
            "filenamePattern": "**/codesets/*.csv"
          }
        ],
        "priority": "default"
      },
      {
        "viewType": "messagefoundry.stepsEditor",
        "displayName": "MessageFoundry Steps",
        "selector": [
          {
            "filenamePattern": "**/*.py"
          }
        ],
        "priority": "option"
      }
    ],
    "chatParticipants": [
      {
        "id": "messagefoundry.chat",
        "name": "messagefoundry",
        "fullName": "MessageFoundry",
        "description": "Ask about Connections, Routers, and Handlers (PHI-safe — code & schema only).",
        "isSticky": true,
        "commands": [
          {
            "name": "explain",
            "description": "Explain the selected HL7 path, Router, or Handler"
          },
          {
            "name": "transform",
            "description": "Draft a Handler transform for what you describe"
          },
          {
            "name": "router",
            "description": "Draft a Router for the routing policy you describe"
          },
          {
            "name": "review",
            "description": "Review the active Router/Handler for PHI leaks and bugs"
          },
          {
            "name": "migrate",
            "description": "Convert pasted Mirth/Corepoint logic to a Router/Handler"
          },
          {
            "name": "test",
            "description": "Generate a synthetic HL7 sample for the active code"
          }
        ]
      }
    ],
    "walkthroughs": [
      {
        "id": "messagefoundry.gettingStarted",
        "title": "Get Started with MessageFoundry",
        "description": "Wire your first Connection, Route, and Handler — then test it, without touching a real engine.",
        "steps": [
          {
            "id": "pointAtEngine",
            "title": "Point at the engine",
            "description": "Tell the IDE which running engine you'll promote to, and watch the status bar for reachability.\n[Configure Engine Target](command:messagefoundry.openEngineSettings)",
            "media": {
              "markdown": "media/walkthrough/point-at-engine.md"
            },
            "completionEvents": [
              "onCommand:messagefoundry.openEngineSettings"
            ]
          },
          {
            "id": "openConfigDir",
            "title": "Open the config dir",
            "description": "Your Connections, Routers, and Handlers live as Python under the config dir — open it to browse them.\n[Open Config Folder](command:messagefoundry.openConfigDir)",
            "media": {
              "markdown": "media/walkthrough/open-config-dir.md"
            },
            "completionEvents": [
              "onCommand:messagefoundry.openConfigDir"
            ]
          },
          {
            "id": "newConnection",
            "title": "Create a Connection",
            "description": "Wire an inbound or outbound endpoint (MLLP, file, …).\n[Open Connection Wizard](command:messagefoundry.newConnection)",
            "media": {
              "markdown": "media/walkthrough/new-connection.md"
            },
            "completionEvents": [
              "onCommand:messagefoundry.newConnection"
            ]
          },
          {
            "id": "newRoute",
            "title": "Wire a Route",
            "description": "Bind a Router + Handler(s) between two Connections — no bundled \"channel\" element, just named pieces.\n[Open Route Wizard](command:messagefoundry.newRoute)",
            "media": {
              "markdown": "media/walkthrough/new-route.md"
            },
            "completionEvents": [
              "onCommand:messagefoundry.newRoute"
            ]
          },
          {
            "id": "insertElement",
            "title": "Insert a Handler idiom",
            "description": "Drop a field copy, lookup, loop, or Send as real, editable Python.\n[Insert Element](command:messagefoundry.insertElement)",
            "media": {
              "markdown": "media/walkthrough/insert-element.md"
            },
            "completionEvents": [
              "onCommand:messagefoundry.insertElement"
            ]
          },
          {
            "id": "testBench",
            "title": "Dry-run in the Test Bench",
            "description": "Load a message set and see disposition + before/after — no engine, no sending.\n[Open Test Bench](command:messagefoundry.openTestBench)",
            "media": {
              "markdown": "media/walkthrough/test-bench.md"
            },
            "completionEvents": [
              "onCommand:messagefoundry.openTestBench"
            ]
          },
          {
            "id": "liveDebug",
            "title": "Watch it run live",
            "description": "Toggle Live Debug: every save re-runs a dry-run over a synthetic sample and annotates your code — redacted by default.\n[Toggle Live Debug](command:messagefoundry.toggleLiveDebug)",
            "media": {
              "markdown": "media/walkthrough/live-debug.md"
            },
            "completionEvents": [
              "onCommand:messagefoundry.toggleLiveDebug"
            ]
          },
          {
            "id": "cookbook",
            "title": "Browse the Cookbook",
            "description": "Search solved problems — crosswalks, batch splits, enrichment, fan-out — and insert the editable Python.\n[Open Cookbook](command:messagefoundry.openCookbook)",
            "media": {
              "markdown": "media/walkthrough/cookbook.md"
            },
            "completionEvents": [
              "onCommand:messagefoundry.openCookbook"
            ]
          },
          {
            "id": "promote",
            "title": "Stage → Promote",
            "description": "Ship the validated graph to a running engine — staged, pre-flighted against the target's env() values, then an atomic swap.\n[Stage → Promote](command:messagefoundry.promote)",
            "media": {
              "markdown": "media/walkthrough/promote.md"
            },
            "completionEvents": [
              "onCommand:messagefoundry.promote"
            ]
          }
        ]
      }
    ],
    "configuration": {
      "title": "MessageFoundry",
      "properties": {
        "messagefoundry.pythonPath": {
          "type": "string",
          "default": "python",
          "scope": "machine",
          "description": "Python interpreter used to run the `messagefoundry` CLI. Machine-scoped: a checked-in workspace .vscode/settings.json cannot override it to a malicious interpreter that would run on the next CLI/debug launch."
        },
        "messagefoundry.configDir": {
          "type": "string",
          "default": "samples/config",
          "description": "Config modules directory (relative to the workspace)."
        },
        "messagefoundry.serviceConfig": {
          "type": "string",
          "default": "messagefoundry.toml",
          "description": "Service-settings TOML the engine loads (relative to the workspace). The Alert Wizard reads/writes its [[alerts.rules]] (ADR 0014); created on first add if absent."
        },
        "messagefoundry.engineUrl": {
          "type": "string",
          "default": "http://127.0.0.1:8765",
          "scope": "machine",
          "description": "Engine API URL used by Stage → Promote when no named environments are configured (see messagefoundry.environments). Machine-scoped: a checked-in workspace .vscode/settings.json cannot retarget promote to an attacker host that would then receive your credentials and session token."
        },
        "messagefoundry.environments": {
          "type": "array",
          "default": [],
          "scope": "machine",
          "markdownDescription": "Named promote targets for Stage → Promote (e.g. DEV/PROD). When set, promote asks which to target; when empty, it uses `messagefoundry.engineUrl`. Each engine resolves its own environment values, so the same config promotes to each. Machine-scoped: a checked-in workspace .vscode/settings.json cannot retarget promote to an attacker host that would then receive your credentials and session token.",
          "items": {
            "type": "object",
            "required": [
              "name",
              "url"
            ],
            "properties": {
              "name": {
                "type": "string",
                "description": "Display name, e.g. DEV or PROD."
              },
              "url": {
                "type": "string",
                "description": "Engine API URL, e.g. https://prod-host:8765."
              },
              "shards": {
                "type": "array",
                "markdownDescription": "Optional engine instances (shards/replicas) within this environment. When 2 or more are listed, Stage → Promote asks WHICH instance to deploy to and uses that shard's `url`; with 0 or 1 it behaves exactly as a shard-less environment (no extra prompt). Additive — omit it to keep today's single-target behavior.",
                "items": {
                  "type": "object",
                  "required": [
                    "name",
                    "url"
                  ],
                  "properties": {
                    "name": {
                      "type": "string",
                      "description": "Display name for this engine instance, e.g. shard-1 or us-east."
                    },
                    "url": {
                      "type": "string",
                      "description": "This instance's Engine API URL, e.g. https://prod-shard-1:8765."
                    }
                  }
                }
              }
            }
          }
        },
        "messagefoundry.messageSetsDir": {
          "type": "string",
          "default": "samples/messages",
          "description": "Default folder the Test Bench's 'Load Message Set' dialog opens to."
        },
        "messagefoundry.sourceControl.autoPrompt": {
          "type": "boolean",
          "default": true,
          "description": "Offer to set up version control + commit-time checks when a config project has no git repo yet."
        },
        "messagefoundry.ai.contextCharLimit": {
          "type": "integer",
          "default": 8000,
          "minimum": 0,
          "markdownDescription": "Maximum characters of the active editor's code attached to a `@messagefoundry` AI chat request. The assistant only ever sends code + your config graph's names — never message bodies/PHI — so this bounds how much of your *own* code leaves to your chosen model provider. Files larger than the limit are truncated on a line boundary with a visible marker; `0` sends only the graph names (no editor code)."
        },
        "messagefoundry.liveDebug.debounceMs": {
          "type": "integer",
          "default": 400,
          "minimum": 0,
          "markdownDescription": "Debounce (milliseconds) before Live Debug re-runs `dryrun` after a config file is saved. A save-storm coalesces to a single run of the newest content. Only used when Live Debug is toggled on."
        },
        "messagefoundry.liveStatus.enabled": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "Decorate Inbound/Outbound rows in the CONNECTIONS view with live runtime status and message counts polled from the engine's monitoring API (`GET /connections`). Reuses the session Stage → Promote signed in with — the poll itself never prompts; without a session (on an auth-required engine) rows simply stay undecorated. Shows status words and counts only — never message content."
        },
        "messagefoundry.liveStatus.intervalSeconds": {
          "type": "integer",
          "default": 10,
          "minimum": 5,
          "markdownDescription": "How often (seconds) to poll the engine for live status when `#messagefoundry.liveStatus.enabled#` is on. Values below 5 are clamped to 5."
        },
        "messagefoundry.revealViewOnStartup": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "When this workspace opens, reveal the MessageFoundry sidebar (Home / Connections / Translation Tables) instead of the default Explorer. Best set per-workspace in `.vscode/settings.json` so only your MessageFoundry config repos open to it."
        }
      }
    }
  },
  "scripts": {
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "typecheck": "tsc --noEmit",
    "compile-tests": "tsc -p ./tsconfig.test.json",
    "pretest": "npm run compile && npm run compile-tests",
    "test": "node ./out/test/runTest.js",
    "package": "vsce package",
    "vscode:prepublish": "node -e \"require('fs').copyFileSync('../LICENSE','LICENSE')\" && npm run compile"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.19.43",
    "@types/vscode": "~1.95.0",
    "@vscode/test-electron": "^3.0.0",
    "@vscode/vsce": "^3.0.0",
