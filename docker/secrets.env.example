#
# Copy to docker/secrets.env (gitignored) and fill in. Used by docker/compose.yaml's env_file.
# Plain env is visible in `docker inspect` — for stricter handling use a secrets manager or the k8s
# manifests (secretKeyRef). NEVER commit a filled-in secrets.env.

# Store at-rest cipher key — base64 of 32 random bytes. Mint with:  messagefoundry gen-key
MEFOR_STORE_ENCRYPTION_KEY=

# Passphrase for an ENCRYPTED API TLS private key (omit if the key is unencrypted).
MEFOR_API_TLS_KEY_PASSWORD=

# SQL Server / Postgres store login password, if using a server-DB backend (the -sqlserver image).
# MEFOR_STORE_PASSWORD=
