ClusterStatus: clustered, config_version, is_leader, node_id, role
ConfigProvenance: drift, files, fingerprint, git_head, loaded
ConnectionEventInfo: connection, direction, id, kind, message_id, peer_host, reason, transport, ts
ConnectionRow: alerts_active, backlog_seconds, channel_id, channel_name, delivered_age_seconds, destination, direction, error, errored, idle_seconds, method, name, owner_shard, paused, peer, port, queue_depth, read, role, simulated, status, written
DeadLetterList: dead_letters, limit, offset, total
DeadLetterReplayRequest: channel_id, destination_name
DrStatus: activation_mode, active, enabled, threshold
IntegrityResult: detail, ok
MessageDetail: channel_id, control_id, error, event, events, id, message_type, metadata, outbox, raw, received_at, source_type, status, summary
MessageList: limit, messages, offset, total
MessageSearchResults: limit, matched, messages, scan_limit, scanned, truncated
PendingApprovalResponse: approval_id, detail, operation, status
ReloadRequest: config_dir, dry_run
ReloadResult: dry_run, handlers, inbound, outbound, routers, running
SecurityPosture: allow_unencrypted_phi, backend, data_class, encryption_enabled, environment, key_id, key_source, plaintext_columns, production, require_encryption
ServiceStatusInfo: enabled, service_name, state
StatsResetRequest: all, targets
StatsResetTarget: channel_id, destination, role
SystemStatus: db, engine, logs, pool, update

