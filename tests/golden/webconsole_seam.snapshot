## api.security surface (imported directly by the console, outside UiDeps)
authorize_ws: (websocket: 'WebSocket', *permissions: 'Permission') -> 'Identity | None'
get_auth: (request: 'Request') -> 'AuthService | None'
require: (*permissions: 'Permission') -> 'Callable[[Request], Awaitable[Identity]]'
require_reauth_only: (*permissions: 'Permission') -> 'Callable[[Request], Awaitable[Identity]]'
require_step_up: (*permissions: 'Permission') -> 'Callable[[Request], Awaitable[Identity]]'
ws_token: (websocket: 'WebSocket') -> 'str | None'

## AuthService methods called by the console
allow_login_attempt: (self, client: 'str | None') -> 'bool'
allow_phi_read: (self, actor: 'str') -> 'bool'
audit_kerberos_reject: (self, reason: 'str') -> 'None'
audit_permission_denied: (self, identity: 'Identity', permission: 'Permission', path: 'str') -> 'None'
authenticate_kerberos: (self, token: 'bytes', *, client: 'str | None' = None, seed_reauth: 'bool' = True) -> 'LoginOutcome'
begin_webauthn_assertion: (self, token: 'str | None', *, rp_id: 'str') -> 'str | None'
begin_webauthn_registration: (self, identity: 'Identity', *, token: 'str', rp_id: 'str', rp_name: 'str') -> 'str'
confirm_mfa_enrollment: (self, identity: 'Identity', code: 'str', *, token: 'str', client: 'str | None' = None) -> 'list[str] | None'
delete_webauthn_credential: (self, identity: 'Identity', credential_id_hash: 'str', *, client: 'str | None' = None) -> 'bool'
finish_webauthn_assertion: (self, token: 'str | None', response_json: 'str', *, client: 'str | None' = None, rp_id: 'str', origin: 'str') -> 'bool'
finish_webauthn_registration: (self, identity: 'Identity', response_json: 'str', *, label: 'str', token: 'str', client: 'str | None' = None, rp_id: 'str', origin: 'str') -> 'bool'
flag_new_client_ip: (self, token: 'str | None', client_ip: 'str | None', *, path: 'str') -> 'bool'
has_recent_step_up: (self, token: 'str | None') -> 'bool'
identity_for_token: (self, token: 'str | None', *, activity: 'bool' = True) -> 'Identity | None'
list_sessions: (self, user_id: 'str') -> 'list[SessionRecord]'
login: (self, username: 'str', password: 'str', *, provider: 'AuthProvider' = <AuthProvider.LOCAL: 'local'>, client: 'str | None' = None) -> 'LoginOutcome'
logout: (self, token: 'str | None', *, actor: 'str | None' = None) -> 'None'
mfa_satisfied: (self, token: 'str | None') -> 'bool'
mfa_status: (self, identity: 'Identity') -> 'MfaStatus'
reauth: (self, identity: 'Identity', password: 'str', *, token: 'str', client: 'str | None' = None, purpose: 'str | None' = None) -> 'bool'
revoke_other_sessions: (self, identity: 'Identity', current_token_hash: 'str', *, actor: 'str') -> 'int'
revoke_own_session: (self, identity: 'Identity', session_id: 'str', *, actor: 'str') -> 'bool'
verify_mfa: (self, token: 'str | None', code: 'str', *, client: 'str | None' = None) -> 'bool'
webauthn_available: (self) -> 'bool'

