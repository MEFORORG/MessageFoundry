#
# Keep the engine image build context small and free of anything sensitive. docker/Dockerfile COPYs
# only: pyproject.toml, README.md, LICENSE, NOTICE, messagefoundry/, and docker/locks/. Everything
# else is excluded so it can never end up in an image layer (PHI, secrets, dev tooling, the GUI harness).

# VCS / editor / caches
**/.git
**/.gitignore
**/.venv
**/__pycache__
**/*.pyc
**/.pytest_cache
**/.mypy_cache
**/.ruff_cache
**/.DS_Store

# Local stores / logs / secrets — never in an image
*.db
*.db-wal
*.db-shm
*.log
*.env
.env
**/*.pem
**/*.key

# Not needed in the engine image (the web console + PySide6 harness are host-side; tests/docs/samples are not shipped)
.claude/
.github/
docs/
tests/
harness/
samples/
scripts/
environments/
ide/
node_modules/
migration-local/
out/
